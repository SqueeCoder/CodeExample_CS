}
public class Position
{
    public int X { get; set; }
    public int Y { get; set; }
    public Position(int x, int y)
    {
        X = x;
        Y = y;
    }
    public static Position operator +(Position position, int range)
    {
        int posX = position.X + range;
        int posY = position.Y + range;
        int width = Data.GetInstance().Map.Width;
        int height = Data.GetInstance().Map.Height;

        if (posX >= width)
            posX = width - 1;
        if (position.Y + range >= height)
            posY = height - 1;

        return new Position(posX, posY);
    }
    public static Position operator -(Position position, int range)
    {
        int posX = position.X + range;
        int posY = position.Y + range;
        int width = Data.GetInstance().Map.Width;
        int height = Data.GetInstance().Map.Height;

        if (posX < 0)
            posX = 0;
        if (position.Y + range < 0)
            posY = 0;

        return new Position(posX, posY);
    }
}
