class MyPac : Pac
{
    public bool HasMoved = false;
    public bool HasTask = false;
    public Position TargetPosition { get; set; }
    public Region Sector;
    public void Move(Position target)
    {
        if (!HasMoved)
            data.Answer += $"MOVE {Id} {Position.X} {Position.Y}|";
    }
    public void MoveToSector()
    {
        Region sector = null;
        FindSector();
        CreateTask();
        
        void FindSector()
        {
            int distance = 0;
            for (int i = 0; i < data.Sectors.Count; i++)
            {
                int _dist = Analizator.GetDistance(Position, data.Sectors[i].Position);
                if (i == 0 || distance > _dist)
                {
                    distance = _dist;
                    sector = data.Sectors[i];
                    data.Sectors.Remove(sector);
                }
            }

        }
        void CreateTask()
        {
            TargetPosition = Analizator.GetClosestPosition(sector.NotVisited, Position);
            HasTask = true;
            if (!HasMoved)
            {
                data.Answer += $"MOVE {Id } {TargetPosition.X} {TargetPosition.Y}|";
                HasMoved = true;
            }
        }
    }
    public void Task()
    {
        if (!HasTask) return;
        if (TargetPosition == Position)
        {
            HasTask = false;
        } else  if (!HasMoved)
        {
            data.Answer += $"MOVE {Id } {TargetPosition.X} {TargetPosition.Y}|";
            HasMoved = true;
        }
    }

}
